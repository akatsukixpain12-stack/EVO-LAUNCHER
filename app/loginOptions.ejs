<div id="loginOptionsContainer" style="display: none;">
    <div id="loginOptionsContent">
        <div class="loginOptionsMainContent">
            <div class="loginOptionsHeader">
                <div class="loginOptionsHeaderIcon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </div>
                <div class="loginOptionsHeaderText">
                    <h2><%- lang('loginOptions.loginOptionsTitle') %></h2>
                    <span class="loginOptionsHeaderDesc">Manage your Minecraft accounts</span>
                </div>
            </div>

            <div class="loginOptionsGettingStarted">
                <span class="gettingStartedBadge">Getting Started</span>
                <h3>Welcome! Let's set up your account</h3>
                <p>Before you can play Minecraft, you need to add an account. Choose a local profile for LAN and singleplayer, or sign in with your Microsoft account for the full experience.</p>
                <div class="gettingStartedSteps">
                    <div class="gettingStartedStep">
                        <span class="stepNumber">1</span>
                        <div class="stepContent">
                            <strong>Add an account</strong>
                            <span>Choose local profile or online login</span>
                        </div>
                    </div>
                    <div class="gettingStartedStep">
                        <span class="stepNumber">2</span>
                        <div class="stepContent">
                            <strong>Create a profile</strong>
                            <span>Configure your game settings</span>
                        </div>
                    </div>
                    <div class="gettingStartedStep">
                        <span class="stepNumber">3</span>
                        <div class="stepContent">
                            <strong>Start playing!</strong>
                            <span>Launch Minecraft and enjoy</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="loginOptionsMethodHeader">
                <span>Choose your login method:</span>
            </div>

            <div class="loginOptionActions">
                <div class="loginOptionCard" id="loginOptionOfflineCard">
                    <button id="loginOptionOffline" class="loginOptionCardButton">
                        <div class="loginOptionCardIcon loginOptionCardIconOffline">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                        </div>
                        <div class="loginOptionCardText">
                            <span class="loginOptionCardTitle">Local Profile</span>
                            <span class="loginOptionCardDesc">Authorization without a password</span>
                        </div>
                        <div class="loginOptionCardArrow">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                        </div>
                    </button>
                </div>

                <div class="loginOptionCard" id="loginOptionMicrosoftCard">
                    <button id="loginOptionMicrosoft" class="loginOptionCardButton">
                        <div class="loginOptionCardIcon loginOptionCardIconMicrosoft">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 23 23">
                                <path fill="#f35325" d="M1 1h10v10H1z" />
                                <path fill="#81bc06" d="M12 1h10v10H12z" />
                                <path fill="#05a6f0" d="M1 12h10v10H1z" />
                                <path fill="#ffba08" d="M12 12h10v10H12z" />
                            </svg>
                        </div>
                        <div class="loginOptionCardText">
                            <span class="loginOptionCardTitle">Microsoft Account</span>
                            <span class="loginOptionCardDesc">Full access to multiplayer servers</span>
                        </div>
                        <div class="loginOptionCardArrow">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                        </div>
                    </button>
                </div>

                <div class="loginOptionCard" id="loginOptionElyByCard">
                    <button id="loginOptionElyBy" class="loginOptionCardButton">
                        <div class="loginOptionCardIcon loginOptionCardIconElyBy">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4caf50" stroke-width="2">
                                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                                <path d="M2 17l10 5 10-5"/>
                                <path d="M2 12l10 5 10-5"/>
                            </svg>
                        </div>
                        <div class="loginOptionCardText">
                            <span class="loginOptionCardTitle">Ely.by Account</span>
                            <span class="loginOptionCardDesc">Free account with skin support</span>
                        </div>
                        <div class="loginOptionCardArrow">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                        </div>
                    </button>
                </div>

                <div class="loginOptionCard" id="loginOptionMojangCard">
                    <button id="loginOptionMojang" class="loginOptionCardButton">
                        <div class="loginOptionCardIcon loginOptionCardIconMojang">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 9.677 9.667">
                                <path d="M-26.332-12.098h2.715c-1.357.18-2.574 1.23-2.715 2.633z" fill="#fff" />
                                <path d="M2.598.022h7.07L9.665 7c-.003 1.334-1.113 2.46-2.402 2.654H0V2.542C.134 1.2 1.3.195 2.598.022z" fill="#db2331" />
                                <path d="M1.54 2.844c.314-.76 1.31-.46 1.954-.528.785-.083 1.503.272 2.1.758l.164-.9c.327.345.587.756.964 1.052.28.254.655-.342.86-.013.42.864.408 1.86.54 2.795l-.788-.373C6.9 4.17 5.126 3.052 3.656 3.685c-1.294.592-1.156 2.65.06 3.255 1.354.703 2.953.51 4.405.292-.07.42-.34.87-.834.816l-4.95.002c-.5.055-.886-.413-.838-.89l.04-4.315z" fill="#fff" />
                            </svg>
                        </div>
                        <div class="loginOptionCardText">
                            <span class="loginOptionCardTitle">Mojang Account</span>
                            <span class="loginOptionCardDesc">Legacy Mojang authentication</span>
                        </div>
                        <div class="loginOptionCardArrow">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                        </div>
                    </button>
                </div>
                <div class="loginOptionButtonContainer">
                    <button id="loginOptionElyBy" class="loginOptionButton">
                        <span style="font-weight: 700; min-width: 22px; text-align: center;">E</span>
                        <span><%- lang('loginOptions.loginWithElyBy') %></span>
                    </button>
                </div>
            </div>

            <div id="loginOptionCancelContainer" style="display: none;">
                <button id="loginOptionCancelButton"><%- lang('loginOptions.cancelButton') %></button>
            </div>
        </div>
    </div>
    <script src="./assets/js/scripts/loginOptions.js"></script>
</div>
